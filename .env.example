# ========== LLM Configuration ==========
LLM_PROVIDER="gemini"               # Options: "gemini" | "claude"
GEMINI_API_KEY="your-gemini-key"
ANTHROPIC_API_KEY="your-anthropic-key"

# ========== Telegram ==========
TELEGRAM_BOT_TOKEN="your-telegram-bot-token"
TELEGRAM_WEBHOOK_URL=""             # Leave empty for polling mode
ALLOWED_USER_IDS="123456,789012"  # List of comma-separated Telegram User IDs

# ========== Google OAuth 2.0 ==========
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:8080/oauth/callback"

# ========== Voice Transcription ==========
OPENAI_API_KEY="your-openai-key"
VOICE_PROVIDER="whisper"            # Options: "whisper" | "gemini"

# ========== Database ==========
DATABASE_URL="sqlite+aiosqlite:///./secretarai.db"

# ========== Geo Settings ==========
DEFAULT_GEOFENCE_RADIUS_METERS=100

# ========== PC Automation ==========
PC_AUTOMATION_ENABLED=false
PC_AUTOMATION_MODE="pyautogui"      # Options: "pyautogui" | "claude_computer_use"
